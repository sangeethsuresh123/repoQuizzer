# ── LLM (OpenRouter) ──────────────────────────────────────────────────
NVIDIA_API_KEY=sk-or-v1-...               # your OpenRouter API key
NVIDIA_BASE_URL=https://openrouter.ai/api/v1
LLAMA_MODEL=meta-llama/llama-3.3-70b-instruct

# ── Database ───────────────────────────────────────────────────────────
# Set to a Postgres URL for production.  Omit for local SQLite dev.
# DATABASE_URL=postgresql://repoquizzer:repoquizzer@localhost:5432/repoquizzer

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
